{% extends "base.html.j2" %}

{% block content %}
<article class="demo-page">
  <header class="demo-page__header">
    <a class="article-breadcrumb" href="{{ asset_base | default('') }}exhibits.html">Exhibits</a>
  </header>
  <div class="badge-row">
    {% if not card.doctrine %}<span class="synthetic-badge">SYNTHETIC DATA</span>{% endif %}
    {% for tier in card.tiers %}<span class="tier-badge" data-tier="{{ tier }}">{{ tier }} · {{ {'R': 'Returns', 'E': 'Exposures', 'P': 'Positions'}[tier] }}</span>{% endfor %}
  </div>
  <h1 class="demo-page__title">{{ card.title }}</h1>
  <p class="demo-page__oneliner">{{ card.one_liner }}</p>

  <section class="demo-decision" aria-labelledby="demo-decision-title">
    <p class="demo-decision__eyebrow">Decision question</p>
    <h2 id="demo-decision-title">{{ card.decision_question }}</h2>
  </section>

  {% block demo_lead %}{% endblock %}

  {% block card_data %}
  {% if not card.doctrine %}
  <script type="application/json" id="card-data">{{ card_data_json | safe }}</script>
  {% endif %}
  {% endblock %}

  {% block demo_content %}{% endblock %}

  <details class="evidence-appendix">
    <summary>Evidence and readiness</summary>
    <div class="evidence-appendix__body">
      {% block decision_context %}
      <section class="card-context" aria-labelledby="card-context-title">
        <div class="card-context__lead">
          <h2 id="card-context-title">Decision context</h2>
          <p>{{ card.decision_question }}</p>
        </div>
        <dl class="card-context__facts">
          <div><dt>Primary stage</dt><dd>{{ stage_headings[card.primary_stage] }}</dd></div>
          <div><dt>Maturity</dt><dd>{{ labels[card.decision_readiness] }}</dd></div>
          <div><dt>Minimum data</dt><dd>{{ card.minimum_data }}</dd></div>
          <div><dt>Asset scope</dt><dd>{% for token in card.asset_classes %}{{ labels[token] }}{% if not loop.last %}; {% endif %}{% endfor %}</dd></div>
          <div><dt>Vehicle scope</dt><dd>{% for token in card.vehicle_types %}{{ labels[token] }}{% if not loop.last %}; {% endif %}{% endfor %}</dd></div>
          <div><dt>Access</dt><dd>{% for token in card.access_contexts %}{{ labels[token] }}{% if not loop.last %}; {% endif %}{% endfor %}</dd></div>
          <div><dt>Access semantics</dt><dd>{% for claim in card.claims %}<span class="attestation-chip access-semantics-chip" data-claim-id="{{ claim.id }}" data-access-semantics="{{ claim.access_semantics }}">{{ claim.id }} · {{ labels[claim.access_semantics] }}</span>{% if not loop.last %} {% endif %}{% endfor %}</dd></div>
          <div><dt>Validation</dt><dd>{{ labels[card.validation_status] }}</dd></div>
          <div><dt>Attestation</dt><dd>{% for claim in card.claims %}<span class="attestation-chip">Current {{ claim.current_attestation }} · Live ceiling {{ claim.live_attestation_ceiling }}</span>{% if not loop.last %} {% endif %}{% endfor %}</dd></div>
        </dl>
      </section>
      {% endblock %}

      <section class="demo-methodology">
        <h2>Methodology</h2>
        {% block methodology %}{% endblock %}
      </section>

      {% if card.doctrine %}
      <aside class="usage-note">
        <h2>How to use this</h2>
        <p>{{ card.usage_note }}</p>
      </aside>
      {% elif card.standing_note %}
      <aside class="golive-replaced" role="note">
        <h2>No go-live</h2>
        <p>{{ card.standing_note }}</p>
      </aside>
      {% else %}
      <dl class="golive-box">
        <dt>Data ask</dt><dd>{{ card.golive.data_ask }}</dd>
        <dt>Sample required</dt><dd>{{ card.golive.sample }}</dd>
        <dt>Build effort</dt><dd>{{ card.golive.effort }}</dd>
      </dl>
      {% endif %}
    </div>
  </details>

  <p class="spec-link">
    <a href="{{ asset_base | default('') }}specs/{{ card.id }}.html">Read the full article</a>
  </p>

  {% if curriculum_previous or curriculum_next %}
  <nav class="article-continuation exhibit-continuation" aria-label="Continue the foundation path">
    {% if curriculum_previous %}
    <div>
      <p>Previous in this path</p>
      <a href="{{ curriculum_previous.href }}">{{ curriculum_previous.title }}</a>
    </div>
    {% endif %}
    {% if curriculum_next %}
    <div>
      <p>Next in this path</p>
      <a href="{{ curriculum_next.href }}">{{ curriculum_next.title }}</a>
    </div>
    {% endif %}
  </nav>
  {% endif %}
</article>
{% endblock %}
