{% extends "base.html.j2" %}

{% block head_extra %}
<link rel="stylesheet" href="{{ asset_base | default('') }}assets/katex/katex.min.css">
{% endblock %}

{% block content %}
<article class="spec-page article-shell">
  <header class="article-shell__header">
    <nav class="article-breadcrumb" aria-label="Breadcrumb">
      <a href="{{ asset_base | default('') }}index.html#research">Research</a>
      <span aria-hidden="true">/</span>
      <span>{{ card.lane }}</span>
    </nav>
    <a class="article-link" href="{{ asset_base | default('') }}{{ card.id }}.html">Open the paired exhibit</a>
  </header>
  <section class="article-intro" aria-labelledby="article-title">
    <p class="article-intro__kicker">{{ card.lane }} research · {{ stage_headings[card.primary_stage] }}</p>
    <h1 id="article-title">{{ card.title }}</h1>
    <p class="article-intro__deck">{{ card.one_liner }}</p>
    <dl class="article-intro__meta">
      <div><dt>Decision</dt><dd>{{ card.decision_question }}</dd></div>
      <div><dt>Maturity</dt><dd>{{ labels[card.decision_readiness] }}</dd></div>
      <div><dt>Minimum evidence</dt><dd>{{ card.minimum_data }}</dd></div>
    </dl>
  </section>
  <div class="spec-page__body" data-math-render-status="error">
    {{ spec_html | safe }}
  </div>
</article>
{% endblock %}

{% block body_scripts %}
<script defer src="{{ asset_base | default('') }}assets/katex/katex.min.js"></script>
<script defer src="{{ asset_base | default('') }}assets/katex/contrib/auto-render.min.js"></script>
<script>
  window.addEventListener("DOMContentLoaded", function () {
    var specBody = document.querySelector(".spec-page__body");
    var mathErrors = [];

    function textHasRawDollar(text) {
      return text.indexOf("$") !== -1;
    }

    function hasRawMathDelimiter(node) {
      if (node.nodeType === 3) return textHasRawDollar(node.nodeValue || "");
      if (node.nodeType !== 1) return false;
      if (node.matches("pre, code, .escaped-dollar, .katex")) return false;
      return Array.prototype.some.call(node.childNodes, hasRawMathDelimiter);
    }

    renderMathInElement(specBody, {
      delimiters: [
        { left: "$$", right: "$$", display: true },
        { left: "$", right: "$", display: false }
      ],
      throwOnError: true,
      errorCallback: function (message, error) {
        mathErrors.push(message);
        console.error(message, error);
      }
    });
    if (hasRawMathDelimiter(specBody)) {
      var rawMessage = "Spec math rendering left an active raw delimiter";
      mathErrors.push(rawMessage);
      console.error(rawMessage);
    }
    if (mathErrors.length) {
      specBody.setAttribute("data-math-render-status", "error");
      throw new Error("Spec math rendering failed: " + mathErrors.join(" | "));
    }
    specBody.setAttribute("data-math-render-status", "ok");
  });
</script>
{% endblock %}
