{% extends "demo.html.j2" %}
{% set default_state = card_data.states[card_data.meta.default_state] %}

{% block head_extra %}
<link rel="stylesheet" href="{{ asset_base | default('') }}assets/pages/x3.css">
{% endblock %}

{% block demo_content %}
<section class="exhibit-intro" aria-label="What this exhibit shows">
  <h2 class="exhibit-intro__title">What this exhibit shows</h2>
  <div class="exhibit-intro__block">
    <h3 class="exhibit-intro__sub">The answer</h3>
    <p><strong>The named sources resolve to 24 strategies, but coverage cannot be
      calculated.</strong> The missing piece is an explicit assignment from each strategy
      to the allocator's target cells. Without it, a heat map or coverage percentage would
      invent information that the source records do not contain.</p>
  </div>
  <div class="exhibit-intro__block">
    <h3 class="exhibit-intro__sub">How to read it</h3>
    <ul class="exhibit-intro__list">
      <li>Follow the flow from named source rows to resolved strategies.</li>
      <li>Stop at the broken connector: strategy identities are not target-cell assignments.</li>
      <li>Read the eligible cell count as the allocator's chosen research scope, not the world.</li>
      <li>Open the <a href="{{ asset_base | default('') }}specs/{{ card.id }}.html">technical
        method and provenance</a> for the coverage definition and identity gate.</li>
    </ul>
  </div>
</section>

<p class="x3-disclaimer" role="note">{{ card_data.meta.disclaimer }}</p>

<section class="x3-flow" id="x3-visual" data-state-key="{{ card_data.meta.default_state }}"
  aria-labelledby="x3-flow-title">
  <header>
    <p class="x3-kicker">Opening state</p>
    <h2 id="x3-flow-title">Where the coverage calculation stops</h2>
    <p><strong>Source set: public records plus pre-hire submissions.</strong>
      Per-source row counts are not available in this exhibit.</p>
  </header>

  <div class="x3-flow__steps">
    <article class="x3-step x3-step--source">
      <span>1</span>
      <div><h3>Named source records</h3>
        <strong data-x3="source-rows">{{ default_state.source_counts.source_rows }}</strong>
        <p>mapping rows across the selected sources</p>
        <ul id="x3-source-list" class="x3-source-list">
          <li>Public adviser records</li>
          <li>Registered fund records</li>
          <li>Holdings filer records</li>
          <li>RFI and DDQ responses</li>
          <li>Strategy export</li>
        </ul>
      </div>
    </article>

    <article class="x3-step x3-step--resolved">
      <span>2</span>
      <div><h3>Resolved strategies</h3>
        <strong data-x3="canonical-members">{{ default_state.source_counts.canonical_members }}</strong>
        <p>active strategy identities at one consistent grain</p>
        <small><span data-x3="ambiguous-rows">{{ default_state.source_counts.ambiguous_rows }}</span>
          ambiguous row remains outside the resolved count.</small>
      </div>
    </article>

    <article class="x3-step x3-step--broken">
      <span aria-hidden="true">×</span>
      <div><h3>Missing assignment link</h3>
        <p>The source records do not say which target cell each resolved strategy belongs to.
          Name similarity or category order cannot substitute for that link.</p></div>
    </article>

    <article class="x3-step x3-step--eligible">
      <span>3</span>
      <div><h3>Eligible target cells</h3>
        <strong data-x3="eligible-cells">{{ default_state.target_grid.eligible_cells }}</strong>
        <p>cells in the allocator's current research map</p>
        <small><span data-x3="excluded-cells">{{ default_state.target_grid.excluded_cells }}</span>
          cells are outside target scope.</small>
      </div>
    </article>

    <article class="x3-step x3-step--refused">
      <span>4</span>
      <div><h3>Coverage not calculated</h3>
        <strong>Missing denominator linkage</strong>
        <p>No heat map is drawn because no strategy-to-cell assignments exist.</p>
      </div>
    </article>
  </div>
</section>

<section class="x3-controls" aria-label="Choose a precomputed coverage state">
  <label for="x3-cutoff">Evidence date
    <select id="x3-cutoff">
      <option value="early">Early evidence</option>
      <option value="middle">Intermediate evidence</option>
      <option value="latest" selected>Latest available evidence</option>
    </select>
  </label>
  <label for="x3-source">Source set
    <select id="x3-source">
      <option value="public-only">Public records only</option>
      <option value="public-plus-prehire" selected>Public records plus pre-hire submissions</option>
      <option value="full-synthetic-funnel">Full synthetic sourcing funnel</option>
    </select>
  </label>
  <label for="x3-scope">Research scope
    <select id="x3-scope">
      <option value="cross-asset" selected>Cross-asset research map</option>
      <option value="liquid-public-markets">Liquid public-markets map</option>
      <option value="credit-private-markets">Credit and private-markets map</option>
    </select>
  </label>
</section>

<p id="x3-live" class="x3-live" aria-live="polite">Showing the latest available evidence,
  public records plus pre-hire submissions, across the cross-asset research map.</p>
<p id="x3-unsupported" class="x3-notice" hidden>That combination is unavailable, so the
  opening state has been restored.</p>

<details class="x3-details">
  <summary>What else remains unavailable?</summary>
  <div class="x3-details__body">
    <section aria-labelledby="x3-funnel-title">
      <h2 id="x3-funnel-title">Sourcing-funnel conversion</h2>
      <p>Stage counts may be shown only when their cohort membership is explicit. A conversion
        interval remains unavailable until each opportunity is assigned to a defined cohort
        with complete observation windows.</p>
      <ul id="x3-funnel-counts">
        <li>No funnel stage counts are available for this source set.</li>
      </ul>
    </section>
    <section aria-labelledby="x3-boundaries-title">
      <h2 id="x3-boundaries-title">Permanent boundaries</h2>
      <p><strong>Global market coverage:</strong> not a valid output because the world
        denominator is unknown.</p>
      <p><strong>Manager ranking:</strong> not a valid output because this method prioritizes
        research cells, never managers.</p>
    </section>
    <section aria-labelledby="x3-validation-title">
      <h2 id="x3-validation-title">Synthetic identity check</h2>
      <p>The lower bounds are
        {{ "%.4f" | format(card_data.entity_resolution_audit.precision_interval[0]) }} for
        precision and
        {{ "%.4f" | format(card_data.entity_resolution_audit.recall_interval[0]) }} for recall.
        At least 381 accepted true links with no false positives are required. This validates
        the fictional matching example, not live market coverage.</p>
    </section>
  </div>
</details>
{% endblock %}

{% block methodology %}
<p>The method fixes one decision date, source set, research scope, and entity grain. It resolves
  source rows to strategy identities, then asks whether an explicit source-to-target-cell link
  exists before forming a coverage numerator.</p>
<p>The browser selects one of 27 precomputed states. It does not resolve identities, assign
  strategies to cells, form cohorts, calculate coverage, or rank managers.</p>
{% endblock %}

{% block body_scripts %}<script src="{{ asset_base | default('') }}assets/x3-universe.js"></script>{% endblock %}
