{% extends "demo.html.j2" %}

{% block head_extra %}
<link rel="stylesheet" href="{{ asset_base | default('') }}assets/pages/e4-operational-evidence-change.css">
{% endblock %}

{% set default_key = card_data.meta.default_state %}
{% set default_state = card_data.interaction_states[default_key] %}

{% macro cutoff_label(token) %}{% if token == 'early' %}First evidence cutoff{% elif token == 'middle' %}Interim evidence cutoff{% else %}Latest evidence cutoff{% endif %}{% endmacro %}
{% macro source_label(token) %}{% if token == 'public-only' %}Public sources only{% else %}All permitted sources{% endif %}{% endmacro %}
{% macro domain_label(token) %}{{ {
  'all': 'All topics',
  'organisation': 'Organisation',
  'process': 'Process',
  'control': 'Control',
  'provider': 'Service provider',
  'incident': 'Incident'
}[token] }}{% endmacro %}
{% macro state_label(token) %}{{ {
  'all': 'All evidence states',
  'corroborated': 'Corroborated',
  'asserted': 'Single-source assertion',
  'conflicted': 'Conflicting evidence',
  'stale': 'Needs refresh'
}[token] }}{% endmacro %}
{% macro change_label(change) %}{% if change.fact_key[1] == 'provider' %}Fund-administrator appointment{% elif change.fact_key[1] == 'incident' %}NAV-publication incident{% elif change.fact_key[1] == 'process' %}NAV-review process{% elif change.fact_key[1] == 'organisation' %}Investment-team location{% else %}Four-eyes control{% endif %}{% endmacro %}
{% macro change_kind_label(token) %}{% if token == 'explicitly-removed' %}Explicitly removed{% elif token == 'corrected' %}Corrected record{% elif token == 'modified' %}Updated record{% else %}{{ token | replace('-', ' ') | capitalize }}{% endif %}{% endmacro %}
{% macro action_label(token) %}{% if token == 'immediate-clarification' %}Clarify now{% elif token == 'scheduled-reunderwrite' %}Schedule review{% elif token == 'evidence-refresh' %}Refresh evidence{% else %}No new action{% endif %}{% endmacro %}
{% macro queue_question(row) %}{% if row.action_bucket == 'immediate-clarification' %}{% if row.domain == 'incident' %}Clarify the NAV-publication incident and its materiality.{% elif row.domain == 'provider' %}Clarify conflicting evidence about the fund administrator.{% else %}Clarify conflicting evidence about the investment team.{% endif %}{% elif row.action_bucket == 'scheduled-reunderwrite' %}Re-underwrite the dated {{ domain_label(row.domain) | lower }} change.{% elif row.action_bucket == 'evidence-refresh' %}Request current {{ domain_label(row.domain) | lower }} evidence.{% else %}No new action follows from this evidence.{% endif %}{% endmacro %}
{% macro fact_label(fact) %}{% if fact.domain == 'provider' %}Fund-administrator evidence{% elif fact.domain == 'incident' %}NAV-publication incident evidence{% elif fact.domain == 'process' %}NAV-review process evidence{% elif fact.domain == 'organisation' and fact.predicate == 'employs' %}Investment-team leadership evidence{% elif fact.domain == 'organisation' %}Office-location evidence{% elif fact.predicate == 'tested-by' %}Control-test evidence{% elif fact.predicate == 'method-boundary' %}Method boundary{% else %}Four-eyes control evidence{% endif %}{% endmacro %}
{% macro source_family_label(token) %}{{ {
  'manager-document': 'Manager document',
  'reference-record': 'Independent reference',
  'public-regulatory-record': 'Public regulatory record',
  'control-test': 'Control test',
  'provider-confirmation': 'Provider confirmation',
  'method-policy': 'Method policy'
}[token] }}{% endmacro %}

{% block demo_lead %}
<section class="e4-boundary" aria-labelledby="e4-boundary-title">
  <div>
    <p class="e4-kicker">Decision answer</p>
    <h2 id="e4-boundary-title">Re-underwrite the evidence gaps, not a synthetic score</h2>
    <p><strong data-e4-cutoff>{{ cutoff_label(default_state.cutoff) }}</strong> &middot;
      <strong data-e4-source-view>{{ source_label(default_state.source_view) }}</strong>.
      Based only on evidence available by this cutoff, conflicting, stale, and incomplete
      operational facts require human review.</p>
  </div>
  <span class="verdict-chip" data-verdict="noise">Human review required</span>
</section>

<section class="e4-opening-state" aria-labelledby="e4-opening-state-title">
  <div>
    <p class="e4-kicker">Current answer</p>
    <h2 id="e4-opening-state-title"><span data-e4-action-count>{{ card_data.reunderwriting_queue[default_key] | length }}</span> actions require review</h2>
  </div>
  <p>A categorical work queue is shown; an operational-risk score is not calculated.
    The dates below distinguish when each change took effect from when supporting evidence
    first made it knowable.</p>
</section>
{% endblock %}

{% block demo_content %}
<section class="e4-primary-timeline" data-e4-panel="timeline" aria-labelledby="e4-timeline-title">
  <header>
    <p class="e4-kicker">What changed, and when could we know it?</p>
    <h2 id="e4-timeline-title">Effective date versus first-known date</h2>
  </header>
  <div class="e4-timeline">
    {% for change in card_data.changes %}
    <article data-e4-change-id="{{ change.change_id }}" data-domain="{{ change.fact_key[1] }}"
      {% if change.change_id not in default_state.change_ids %}hidden{% endif %}>
      <div><span>Effective date</span><time>{{ change.effective_at[:10] }}</time></div>
      <div class="e4-timeline__connector" aria-hidden="true">became knowable</div>
      <div><span>First known</span><time>{{ change.first_known_at[:10] }}</time></div>
      <p><strong>{{ change_label(change) }}</strong><small>{{ change_kind_label(change.change_kind) }}</small></p>
    </article>
    {% endfor %}
  </div>
</section>

<section class="e4-primary-queue" aria-labelledby="e4-queue-title">
  <header>
    <p class="e4-kicker">What happens next?</p>
    <h2 id="e4-queue-title">Action queue for this evidence state</h2>
  </header>
  <div class="e4-queue" data-e4-queue>
  {% for row in card_data.reunderwriting_queue[default_key] %}
    <article data-e4-queue-id="{{ row.queue_id }}" data-domain="{{ row.domain }}">
      <span class="e4-state" data-state="{{ row.action_bucket }}">{{ action_label(row.action_bucket) }}</span>
      <p>{{ queue_question(row) }}</p>
    </article>
  {% endfor %}
  </div>
</section>

<section class="e4-primary-refusal" aria-labelledby="e4-refusal-title">
  <p class="e4-kicker">Method boundary</p>
  <h2 id="e4-refusal-title">A single operational judgement is not calculated</h2>
  <p>The evidence can route clarification, re-underwriting, and refresh work. It cannot support
    an &ldquo;operationally clean&rdquo; label, approval, manager rank, hire decision, or fire decision.</p>
  <p><strong data-e4-refusal-count>{{ default_state.data_boundary_refusal_ids | length }}</strong>
    required inputs are excluded in this state because identity, timing, or version evidence is
    incomplete.</p>
</section>

<section class="exhibit-intro" aria-label="What this exhibit shows">
  <h2 class="exhibit-intro__title">What this exhibit shows</h2>
  <div class="exhibit-intro__block">
    <h3 class="exhibit-intro__sub">What you are looking at</h3>
    <p>A point-in-time operational evidence view. It separates effective time from when evidence
      became knowable, preserves disagreement, and routes evidence questions without producing a
      scalar risk score or manager ranking.</p>
  </div>
  <div class="exhibit-intro__block">
    <h3 class="exhibit-intro__sub">How to read it</h3>
    <ul class="exhibit-intro__list">
      <li>Read the paired dates first: document arrival cannot rewrite when a change occurred.</li>
      <li>Read the action queue second: conflicts and unknown incident materiality route to
        clarification before old evidence routes to refresh.</li>
      <li>Change the cutoff or source set only to explore another exact precomputed state.</li>
      <li>Supporting facts and relationships are available after the primary decision path.</li>
    </ul>
  </div>
</section>

<section class="e4-controls" aria-label="Explore another precomputed evidence state">
  <div class="e4-controls__heading">
    <p class="e4-kicker">Optional exploration</p>
    <h2>Change the evidence available to the decision</h2>
  </div>
  <fieldset>
    <legend>Evidence cutoff</legend>
    {% for token in ['early', 'middle', 'latest'] %}
    <button type="button" data-e4-cutoff-control="{{ token }}"
      aria-pressed="{{ 'true' if token == 'latest' else 'false' }}">{{ cutoff_label(token) }}</button>
    {% endfor %}
  </fieldset>
  <fieldset>
    <legend>Sources available</legend>
    {% for token in ['public-only', 'all-entitled'] %}
    <button type="button" data-e4-source-control="{{ token }}"
      aria-pressed="{{ 'true' if token == 'all-entitled' else 'false' }}">{{ source_label(token) }}</button>
    {% endfor %}
  </fieldset>
  <label>Topic
    <select data-e4-domain-control>
      {% for token in ['all', 'organisation', 'process', 'control', 'provider', 'incident'] %}
      <option value="{{ token }}">{{ domain_label(token) }}</option>
      {% endfor %}
    </select>
  </label>
  <label>Evidence state
    <select data-e4-state-control>
      {% for token in ['all', 'corroborated', 'asserted', 'conflicted', 'stale'] %}
      <option value="{{ token }}">{{ state_label(token) }}</option>
      {% endfor %}
    </select>
  </label>
  <button type="button" data-e4-reset>Restore opening state</button>
  <p class="e4-announcer" aria-live="polite" data-e4-announcer>
    Showing the latest evidence cutoff using all permitted sources.
  </p>
  <p class="e4-empty" data-e4-empty hidden>No evidence matches this display-only filter.</p>
</section>

<details class="e4-advanced">
  <summary>Explore supporting facts and relationships</summary>

  <section class="e4-counts" aria-label="Evidence state counts">
    {% for token in ['corroborated', 'asserted', 'conflicted', 'stale'] %}
    <article data-state="{{ token }}">
      <strong data-e4-count="{{ token }}">{{ default_state.state_counts.get(token, 0) }}</strong>
      <span>{{ token }}</span>
    </article>
    {% endfor %}
    <article data-state="refused">
      <strong data-e4-count="refused">{{ default_state.refusal_count }}</strong>
      <span>not calculated</span>
    </article>
  </section>

  <section class="e4-panel" aria-labelledby="e4-graph-title">
    <header><p class="e4-kicker">Relationship view</p><h2 id="e4-graph-title">Supporting operational relationships</h2></header>
    <div class="e4-graph" role="region" aria-label="Operational relationship diagram">
      {% for row in card_data.relationships %}
      <article class="e4-edge" data-e4-relationship-id="{{ row.relationship_id }}"
        aria-label="{{ row.source_label }} {{ row.relation_type | replace('-', ' ') }} {{ row.target_label }}">
        <span>{{ row.source_label }}</span><b>{{ row.relation_type | replace('-', ' ') }}</b><span>{{ row.target_label }}</span>
      </article>
      {% endfor %}
    </div>
  </section>

  <section class="e4-panel" aria-labelledby="e4-table-title">
    <header><p class="e4-kicker">Accessible detail</p><h2 id="e4-table-title">Facts and relationships</h2></header>
    <div class="e4-table-wrap" role="region" aria-label="Operational fact table" tabindex="0">
      <table>
        <thead><tr><th scope="col">Evidence</th><th scope="col">Topic</th><th scope="col">Source type</th><th scope="col">Available from</th></tr></thead>
        <tbody>
        {% for fact in card_data.facts %}
          {% set state_ns = namespace(value='') %}
          {% for state in card_data.state_summary[default_key] %}
            {% if fact.fact_id in state.supporting_fact_ids or fact.fact_id in state.conflicting_fact_ids %}
              {% set state_ns.value = state.state %}
            {% endif %}
          {% endfor %}
          <tr data-e4-fact-id="{{ fact.fact_id }}" data-domain="{{ fact.domain }}" data-evidence-state="{{ state_ns.value }}">
            <td><span class="e4-state" data-state="{{ state_ns.value }}">{{ state_label(state_ns.value) if state_ns.value else 'Policy evidence' }}</span><br>{{ fact_label(fact) }}</td>
            <td>{{ domain_label(fact.domain) }}</td>
            <td>{{ source_family_label(fact.source_family) }}</td>
            <td>{{ fact.available_at[:10] }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
      <table class="e4-relationship-table">
        <caption>Relationship rows equivalent to the diagram</caption>
        <thead><tr><th scope="col">Source</th><th scope="col">Relationship</th><th scope="col">Target</th><th scope="col">Effective interval</th></tr></thead>
        <tbody>
        {% for row in card_data.relationships %}
          <tr data-e4-relationship-row-id="{{ row.relationship_id }}">
            <td>{{ row.source_label }}</td>
            <td>{{ row.relation_type | replace('-', ' ') }}</td>
            <td>{{ row.target_label }}</td>
            <td>{{ row.effective_from[:10] if row.effective_from else 'Single point' }}
              {% if row.effective_to %} to {{ row.effective_to[:10] }}{% elif row.effective_from %} onward{% endif %}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
</details>

<noscript><p class="e4-noscript">The opening timeline, action queue, refusal, and complete supporting tables remain available without JavaScript. Controls require JavaScript only to switch among the six precomputed states.</p></noscript>
{% endblock %}

{% block methodology %}
<p>The method selects the latest accessible revision before applying half-open valid time. It
  compares complete operational keys, counts copied sources once, and applies conflict, stale,
  corroborated, and asserted precedence in that order.</p>
<p>Evidence age is calculated in Python from explicit source freshness, not source arrival time.
  The page switches among six precomputed outputs and never recomputes an age, join, state, or
  queue bucket.</p>
{% endblock %}

{% block body_scripts %}
<script src="{{ asset_base | default('') }}assets/e4-operational-evidence-change.js"></script>
{% endblock %}
