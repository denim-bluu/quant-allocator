{% extends "demo.html.j2" %}

{% block head_extra %}
<link rel="stylesheet" href="{{ asset_base | default('') }}assets/pages/e2-pack.css">
{% endblock %}

{% set tear = card_data.sections | selectattr("section_id", "equalto", "tear_sheet") | first %}
{% set standing = card_data.sections | selectattr("section_id", "equalto", "posterior_standing") | first %}
{% set reported = tear.stats | selectattr("label", "equalto", "Reported Sharpe") | first %}
{% set desmoothed = tear.stats | selectattr("label", "equalto", "De-smoothed Sharpe") | first %}
{% set alpha = tear.stats | selectattr("label", "equalto", "Annualized alpha") | first %}
{% set tier_labels = {"R": "Returns only", "E": "Exposure summaries", "P": "Positions and trades"} %}

{% block demo_content %}
<div class="pack-page">
  <section class="pack-head">
    <p class="pack-head__meta">
      {{ card_data.meta.manager_name }} &middot; {{ tier_labels[card_data.meta.tier] }}
      &middot; {{ card_data.meta.quarter }}
    </p>
    <p class="pack-summary">{{ card_data.summary
      | replace("returns-only tier", "Returns only")
      | replace("tier-E data", "Exposure summaries")
      | replace("source card", "source analysis")
    }}</p>
    <aside class="pack-honesty" role="note">
      Narration in this demonstration is <strong>hand-authored and human-edited</strong>.
      Automatic number checks require every stated value to match the dated analysis
      named beneath its section.
    </aside>
  </section>

  {% for s in card_data.sections %}
    {% if s.state == "rendered" %}
    <section class="pack-section" data-section="{{ s.section_id }}">
      <h2 class="pack-section__title">{{ s.title }}</h2>
      <p class="pack-section__prov">Source analysis: {{ card_titles[s.provenance.card] }}
        &middot; {{ s.provenance.metric | replace("_", " ") }}
        &middot; as of {{ s.provenance.as_of }}</p>
      {% if s.narration %}<p class="pack-narration">{{ s.narration
        | replace("sampler atlas", "calibration study")
        | replace("At the returns-only tier", "With returns only")
        | replace("unlocks at tier E", "becomes available with Exposure summaries")
      }}</p>{% endif %}
      {% if s.stats %}
      <div class="pack-stats">
        {% for stat in s.stats %}
          {% if stat.kind == "interval" %}
          <div class="interval-stat" data-domain="{{ s.section_id }}"
               data-lo="{{ stat.ci_lo }}" data-point="{{ stat.point }}" data-hi="{{ stat.ci_hi }}">
            <span class="interval-stat__label">{{ stat.label }}</span>
            <span class="interval-stat__value">{{ stat.value }}</span>
            <div class="interval-stat__rail">
              <div class="interval-stat__band"></div>
              <div class="interval-stat__point"></div>
            </div>
            <span class="interval-stat__range">{{ stat.range }}</span>
          </div>
          {% else %}
          <span class="verdict-chip" data-verdict="{{ stat.verdict }}">{{ stat.chip }}</span>
          {% endif %}
        {% endfor %}
      </div>
      {% endif %}
      {% if s.views %}
      <ul class="pack-views">
        {% for v in s.views %}
        <li class="pack-view">
          <blockquote class="pack-view__quote">{{ v.quote }}</blockquote>
          <span class="pack-view__meta">{{ v.direction }} &middot; {{ v.theme }}
            &middot; conviction {{ v.conviction }}/3</span>
        </li>
        {% endfor %}
      </ul>
      {% endif %}
    </section>
    {% elif s.state == "refused" %}
    <section class="pack-section" data-section="{{ s.section_id }}">
      <h2 class="pack-section__title">{{ s.title }}</h2>
      <p class="pack-section__prov">Source analysis: {{ card_titles[s.provenance.card] }}
        &middot; {{ s.gate.metric | replace("_", " ") }}</p>
      <div class="power-gate">
        <span class="power-gate__title">Not enough evidence for this section</span>
        <p class="power-gate__reason">{{ s.narration | replace("sampler atlas", "calibration study") }}</p>
        <p class="power-gate__reason">
          {{ s.gate.effect }} needs more {{ s.gate.quantity }} than the reliability
          study covers &mdash;
          {% if s.gate.threshold is none %}no tenure in the measured range suffices{% else %}threshold {{ s.gate.threshold }} {{ s.gate.quantity }}{% endif %}
          (measured {{ s.gate.measured }}).
        </p>
      </div>
    </section>
    {% endif %}
  {% endfor %}

  <footer class="pack-footer">
    <h2 class="pack-footer__title">Source analyses</h2>
    <ul class="pack-footer__prov">
      {% for p in card_data.footer.provenance %}
      <li>{{ p.title }} &mdash; {{ card_titles[p.certified_by] }}</li>
      {% endfor %}
    </ul>
    {% if card_data.footer.omitted %}
    <h2 class="pack-footer__title">Not available with current evidence</h2>
    <ul class="pack-footer__omitted">
      {% for o in card_data.footer.omitted %}
      <li>{{ o.title }} &mdash; available with {{ tier_labels[o.needs_tier] }}</li>
      {% endfor %}
    </ul>
    {% endif %}
  </footer>
</div>

<section class="exhibit-intro" aria-label="What this exhibit shows">
  <h2 class="exhibit-intro__title">What this exhibit shows</h2>
  <div class="exhibit-intro__block">
    <h3 class="exhibit-intro__sub">What you are looking at</h3>
    <p>This is one composed engagement pack for {{ card_data.meta.manager_name }}, a
      returns-only manager, for {{ card_data.meta.quarter }}. It combines reviewed
      analyses into one meeting document without upgrading any conclusion. The
      reported Sharpe is {{ reported.value }}, de-smoothed Sharpe is
      {{ desmoothed.value }}, and the {{ alpha.value }} alpha still has an
      {{ alpha.level }} interval spanning zero. Skill standing remains unavailable at
      {{ standing.gate.measured }} months; exposure drift needs Exposure summaries.</p>
  </div>
  <div class="exhibit-intro__block">
    <h3 class="exhibit-intro__sub">How to read it</h3>
    <p>Read each interval with its verdict and dated source-analysis line. A refused or
      omitted section is part of the document: it states what evidence is missing
      instead of silently disappearing. <a href="{{ asset_base | default('') }}specs/{{ card.id }}.html">Read the full article</a>.</p>
  </div>
</section>
{% endblock %}

{% block methodology %}
<p>The pack performs no statistical estimation. It orders reviewed analysis sections,
preserves each section's evidence threshold and date, and checks that every number in
the narration matches an approved value. Each section is rendered, refused with a
plain reason, or listed as unavailable with current evidence.</p>
{% endblock %}

{% block body_scripts %}
<script src="{{ asset_base | default('') }}assets/e2-pack.js"></script>
{% endblock %}
